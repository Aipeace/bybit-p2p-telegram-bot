{
  "name": "bybit-p2p-telegram-bot",
  "version": "1.0.0",
  "description": "Multi-user Telegram bot + miniapp for Bybit P2P trading",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "init-db": "node backend/init-db.js",
    "bot": "python bot/bot.py",
    "miniapp:build": "cd miniapp && npm run build",
    "miniapp:deploy": "cd miniapp && npm run deploy",
    "miniapp:dev": "cd miniapp && npm run dev"
  },
  "keywords": [
    "bybit",
    "p2p",
    "telegram",
    "bot",
    "miniapp",
    "trading"
  ],
  "author": "Aipeace",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "sqlite3": "^5.1.6",
    "sqlite": "^5.0.1",
    "crypto-js": "^4.1.1",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1",
    "pino": "^8.17.2",
    "pino-pretty": "^10.2.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
