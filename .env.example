# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Bybit P2P API (optional - can be set per-user)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false
BYBIT_DOMAIN=com
BYBIT_TLD=com

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
DEBUG=false

# Database
DB_PATH=./data/users.db
DB_ENCRYPT_KEY=your_secret_key_for_encrypting_credentials

# CORS & Security
CLOUDFLARE_DOMAIN=your-miniapp.workers.dev
ALLOWED_ORIGINS=http://localhost:3000,https://your-miniapp.workers.dev
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Session Management
SESSION_EXPIRY_HOURS=24
SESSION_REFRESH_THRESHOLD_HOURS=1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log
